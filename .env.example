# ══════════════════════════════════════════════════════════════════════
# Quorum — Variables d'environnement
# ══════════════════════════════════════════════════════════════════════
#
# INSTRUCTIONS :
#   1. Copie ce fichier : cp .env.example .env.local
#   2. Remplis chaque valeur (ne laisse JAMAIS une vraie clé dans .env.example)
#   3. .env.local est dans .gitignore — il ne sera jamais commité
#
# ⚠️  RÈGLE CLIENT vs SERVEUR :
#   - Les variables préfixées VITE_  sont exposées au navigateur.
#     → N'y mets QUE des valeurs publiques (URL, clé anon publique).
#   - Les variables SANS préfixe VITE_  restent côté serveur.
#     → Supabase Edge Functions (Deno) ou backend uniquement.
#     → JAMAIS accessibles par le code React/Vite côté client.
#
# ══════════════════════════════════════════════════════════════════════

# ─── OpenRouter ───────────────────────────────────────────────────────
#
# Obtenir une clé GRATUITE :
#   1. Va sur https://openrouter.ai/
#   2. Crée un compte (GitHub/Google acceptés)
#   3. Dashboard → Keys → "Create Key"
#   4. Les modèles suffixés ":free" sont utilisables sans crédits
#      (ex: meta-llama/llama-3.3-70b-instruct:free)
#   5. Pour les modèles premium, ajoute des crédits ($5 minimum)
#
# ⚠️  Cette clé est un SECRET SERVEUR — elle ne doit jamais
#     apparaître dans le code client ni dans les variables VITE_.
#     Elle est utilisée uniquement dans les Supabase Edge Functions.
#
OPENROUTER_API_KEY=sk-or-v1-REMPLACE_PAR_TA_VRAIE_CLE

# ─── Providers gratuits du mode démo (multi-provider) ─────────────────
#
# Le mode démo n'utilise plus OpenRouter `:free` (trop limité) mais des
# providers gratuits OpenAI-compatibles. Une clé par provider (SECRET SERVEUR,
# Edge Functions uniquement — jamais en VITE_) :
#   Cerebras : https://cloud.cerebras.ai/        (Llama 3.1 8B, GPT-OSS 120B)
#   Groq     : https://console.groq.com/keys     (Llama 3.3 70B + Chairman)
#   Gemini   : https://aistudio.google.com/apikey (Gemini 2.5 Flash Lite)
#
CEREBRAS_API_KEY=REMPLACE_PAR_TA_CLE_CEREBRAS
GROQ_API_KEY=REMPLACE_PAR_TA_CLE_GROQ
GEMINI_API_KEY=REMPLACE_PAR_TA_CLE_GEMINI

# ─── Supabase ─────────────────────────────────────────────────────────
#
# Obtenir ces valeurs GRATUITEMENT :
#   1. Va sur https://supabase.com/
#   2. Crée un compte et un nouveau projet (tier Free)
#   3. Settings → API → trouve les 3 valeurs ci-dessous
#
# VITE_SUPABASE_URL — PUBLIC (exposé au client)
#   C'est l'URL de ton projet Supabase, visible dans Settings → API
#   Format : https://[project-ref].supabase.co
#   → Préfixé VITE_ car le client React en a besoin pour faire des requêtes.
#
VITE_SUPABASE_URL=https://REMPLACE_PAR_TON_PROJECT_REF.supabase.co

# VITE_SUPABASE_ANON_KEY — PUBLIC (exposé au client, c'est volontaire)
#   La clé "anon" (anonyme) est PUBLIQUE par design chez Supabase.
#   Elle ne permet d'accéder qu'aux données autorisées par les Row Level
#   Security (RLS) policies. C'est safe de l'exposer au client.
#   Settings → API → "anon public"
#   → Préfixé VITE_ car le SDK Supabase côté client en a besoin.
#
VITE_SUPABASE_ANON_KEY=eyJSEMPLE_REMPLACE_PAR_TA_VRAIE_ANON_KEY

# SUPABASE_SERVICE_ROLE_KEY — SECRET SERVEUR ⛔ JAMAIS côté client
#   La clé "service_role" bypasse TOUTES les RLS policies.
#   Elle donne un accès administrateur complet à ta base de données.
#   → Utilisée UNIQUEMENT dans les Supabase Edge Functions (côté serveur).
#   → JAMAIS de préfixe VITE_ — ne doit jamais atteindre le navigateur.
#   Settings → API → "service_role" (clique sur "Reveal")
#
SUPABASE_SERVICE_ROLE_KEY=eyJSEMPLE_REMPLACE_PAR_TA_VRAIE_SERVICE_ROLE_KEY

# ─── Moteur de consensus (Edge Function `council`) ────────────────────
#
# ⛔ SECRETS SERVEUR — uniquement dans les Edge Functions, jamais côté client.
#    Configurer via `supabase secrets set <NOM>=<valeur>` (ou le dashboard).
#
# BYOK_ENCRYPTION_KEY — clé maître AES-256-GCM (32 octets, encodés en base64)
#   Sert à chiffrer/déchiffrer les clés OpenRouter personnelles (BYOK) stockées
#   dans user_secrets. Générer une valeur aléatoire sûre, ex. :
#     openssl rand -base64 32
#   ⚠️  Ne JAMAIS la committer ni la régénérer après mise en prod (déchiffrement perdu).
#
BYOK_ENCRYPTION_KEY=REMPLACE_PAR_32_OCTETS_BASE64

# RATE_LIMIT_SALT — sel du hash d'IP (anti rainbow-table, l'IP n'est jamais
#   stockée en clair). Générer une valeur aléatoire, ex. `openssl rand -hex 16`.
#
RATE_LIMIT_SALT=REMPLACE_PAR_UN_SEL_ALEATOIRE

# CRON_SECRET — secret protégeant l'Edge Function `generate-daily-questions`
#   (générateur automatique de Questions du Jour). pg_cron l'envoie en header
#   `Authorization: Bearer <CRON_SECRET>` ; la fonction rejette tout appel sans
#   ce secret → elle n'est jamais appelable publiquement. Générer une valeur
#   aléatoire, ex. `openssl rand -hex 32`.
#   ⚠️  À déclarer DEUX fois, de façon cohérente :
#     1. Côté Edge Function :  supabase secrets set CRON_SECRET=<valeur>
#     2. Côté base (lu par le cron via Vault) :
#          select vault.create_secret('<valeur>', 'cron_secret');
#          select vault.create_secret('https://<project-ref>.supabase.co', 'project_url');
#
CRON_SECRET=REMPLACE_PAR_UN_SECRET_ALEATOIRE

# Paramètres optionnels (défauts définis dans _shared/models.ts) :
#   COUNCIL_TIMEOUT_MS       — timeout par modèle, ms        (défaut 30000)
#   RATE_LIMIT_WINDOW_SECONDS— fenêtre de rate limit IP, s   (défaut 60)
#   RATE_LIMIT_MAX_REQUESTS  — requêtes max / fenêtre / IP    (défaut 8)
#   ALLOWED_ORIGIN           — origine CORS autorisée         (défaut *)
#   OPENROUTER_REFERER       — en-tête d'attribution OpenRouter
#
# COUNCIL_TIMEOUT_MS=30000
# RATE_LIMIT_WINDOW_SECONDS=60
# RATE_LIMIT_MAX_REQUESTS=8
# ALLOWED_ORIGIN=http://localhost:5173

# ─── Configuration publique de l'app ──────────────────────────────────
#
# URL publique de l'app (utilisée pour générer les liens OG, partage, etc.)
# En développement : http://localhost:5173
# En production : https://quorum.app (ou ton domaine)
#
VITE_APP_URL=http://localhost:5173

# ─── Déploiement Vercel (SSR partage + image OG) ──────────────────────
#
# Les fonctions serverless api/ (page publique /q/{slug}, image OG, sitemap)
# lisent Supabase via REST avec la clé anon. Sur Vercel, déclare ces variables
# dans Project Settings → Environment Variables (elles sont alors disponibles
# côté fonction via process.env). Les fonctions acceptent les deux noms :
#   SUPABASE_URL / VITE_SUPABASE_URL        (URL projet)
#   SUPABASE_ANON_KEY / VITE_SUPABASE_ANON_KEY  (clé anon PUBLIQUE)
#   VITE_APP_URL                            (domaine public, ex. https://quorum.app)
# Aucune clé service_role ici : tout passe par RLS + RPC publiques.

# ─── Feature flags (optionnel) ────────────────────────────────────────
#
# Activer/désactiver des features en cours de développement.
# "true" | "false" — préfixé VITE_ car utilisé côté client.
#
VITE_FEATURE_QUESTION_DU_JOUR=false
VITE_FEATURE_BYOK=false

# Reverse-trial : X jours de PRO offerts aux nouveaux comptes (à tester).
#   → Désactivé par défaut. L'octroi réel et son unicité sont garantis serveur
#     (RPC start_reverse_trial, migration 0019). La durée fait autorité côté
#     base (billing_config.reverse_trial_days) ; VITE_REVERSE_TRIAL_DAYS n'est
#     qu'un miroir d'affichage.
VITE_FEATURE_REVERSE_TRIAL=false
VITE_REVERSE_TRIAL_DAYS=7

# ─── Monétisation freemium (open-core) ────────────────────────────────
#
# Quotas FREE configurables (miroir client de la table billing_config, qui
# reste l'autorité côté serveur). Ajuster sans toucher au code.
#   VITE_FREE_DAILY_QUESTIONS_ANON  — questions/jour sans compte  (défaut 5)
#   VITE_FREE_DAILY_QUESTIONS       — questions/jour avec compte  (défaut 10)
#
VITE_FREE_DAILY_QUESTIONS_ANON=5
VITE_FREE_DAILY_QUESTIONS=10

# Fournisseur de paiement. Au MVP : "none" → AUCUN paiement déclenché, les CTA
# PRO restent informatifs. Pour activer plus tard, préférer un MERCHANT OF
# RECORD (lemonsqueezy | polar | paddle) plutôt que "stripe" — voir
# docs/MONETISATION.md (l'éditeur étant mineur, le MoR gère TVA/conformité).
#   "none" | "lemonsqueezy" | "polar" | "paddle" | "stripe"
VITE_BILLING_PROVIDER=none

# ─── Analytiques (optionnel) ──────────────────────────────────────────
#
# PostHog pour les analytics (tier free disponible sur https://posthog.com)
# Préfixé VITE_ car le SDK PostHog tourne dans le navigateur.
#
# VITE_POSTHOG_KEY=phc_REMPLACE_PAR_TA_CLE
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
