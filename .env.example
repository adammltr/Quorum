# ══════════════════════════════════════════════════════════════════════
# Quorum — Environment variables
# ══════════════════════════════════════════════════════════════════════
#
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env.local
#   2. Fill in each value (NEVER leave a real key in .env.example)
#   3. .env.local is in .gitignore — it will never be committed
#
# ⚠️  CLIENT vs SERVER RULE:
#   - Variables prefixed with VITE_  are exposed to the browser.
#     → Put ONLY public values here (URL, public anon key).
#   - Variables WITHOUT the VITE_ prefix stay server-side.
#     → Supabase Edge Functions (Deno) or backend only.
#     → NEVER reachable by the React/Vite client code.
#
# ══════════════════════════════════════════════════════════════════════

# ─── OpenRouter ───────────────────────────────────────────────────────
#
# Get a FREE key:
#   1. Go to https://openrouter.ai/
#   2. Create an account (GitHub/Google accepted)
#   3. Dashboard → Keys → "Create Key"
#   4. Models suffixed ":free" are usable without credits
#      (e.g. meta-llama/llama-3.3-70b-instruct:free)
#   5. For premium models, add credits ($5 minimum)
#
# ⚠️  This key is a SERVER SECRET — it must never appear in client code
#     or in VITE_ variables. It is used only inside Supabase Edge Functions.
#
OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_YOUR_REAL_KEY

# ─── Free providers for demo mode (multi-provider) ────────────────────
#
# Demo mode no longer uses OpenRouter `:free` (too limited) but free
# OpenAI-compatible providers. One key per provider (SERVER SECRET,
# Edge Functions only — never VITE_):
#   Cerebras: https://cloud.cerebras.ai/         (Llama 3.1 8B, GPT-OSS 120B)
#   Groq:     https://console.groq.com/keys      (Llama 3.3 70B + Chairman)
#   Gemini:   https://aistudio.google.com/apikey (Gemini 2.5 Flash Lite)
#
CEREBRAS_API_KEY=REPLACE_WITH_YOUR_CEREBRAS_KEY
GROQ_API_KEY=REPLACE_WITH_YOUR_GROQ_KEY
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY

# ─── Supabase ─────────────────────────────────────────────────────────
#
# Get these values for FREE:
#   1. Go to https://supabase.com/
#   2. Create an account and a new project (Free tier)
#   3. Settings → API → find the 3 values below
#
# VITE_SUPABASE_URL — PUBLIC (exposed to the client)
#   The URL of the Supabase project, shown in Settings → API
#   Format: https://[project-ref].supabase.co
#   → Prefixed VITE_ because the React client needs it to make requests.
#
VITE_SUPABASE_URL=https://REPLACE_WITH_YOUR_PROJECT_REF.supabase.co

# VITE_SUPABASE_ANON_KEY — PUBLIC (exposed to the client, by design)
#   The "anon" (anonymous) key is PUBLIC by design in Supabase.
#   It only grants access to data allowed by Row Level Security (RLS)
#   policies. It is safe to expose to the client.
#   Settings → API → "anon public"
#   → Prefixed VITE_ because the client-side Supabase SDK needs it.
#
VITE_SUPABASE_ANON_KEY=eyEXAMPLE_REPLACE_WITH_YOUR_REAL_ANON_KEY

# SUPABASE_SERVICE_ROLE_KEY — SERVER SECRET ⛔ NEVER client-side
#   The "service_role" key bypasses ALL RLS policies.
#   It grants full admin access to the database.
#   → Used ONLY inside Supabase Edge Functions (server-side).
#   → NEVER prefix with VITE_ — it must never reach the browser.
#   Settings → API → "service_role" (click "Reveal")
#
SUPABASE_SERVICE_ROLE_KEY=eyEXAMPLE_REPLACE_WITH_YOUR_REAL_SERVICE_ROLE_KEY

# ─── Consensus engine (Edge Function `council`) ───────────────────────
#
# ⛔ SERVER SECRETS — only inside Edge Functions, never client-side.
#    Configure via `supabase secrets set <NAME>=<value>` (or the dashboard).
#
# BYOK_ENCRYPTION_KEY — AES-256-GCM master key (32 bytes, base64-encoded)
#   Used to encrypt/decrypt users' personal OpenRouter keys (BYOK) stored
#   in user_secrets. Generate a secure random value, e.g.:
#     openssl rand -base64 32
#   ⚠️  Never commit it or regenerate it after going to production (decryption lost).
#
BYOK_ENCRYPTION_KEY=REPLACE_WITH_32_BYTES_BASE64

# RATE_LIMIT_SALT — salt for the IP hash (anti rainbow-table; the IP is
#   never stored in clear text). Generate a random value, e.g. `openssl rand -hex 16`.
#
RATE_LIMIT_SALT=REPLACE_WITH_A_RANDOM_SALT

# CRON_SECRET — secret protecting the `generate-daily-questions` Edge Function
#   (automatic Question of the Day generator). pg_cron sends it in the
#   `Authorization: Bearer <CRON_SECRET>` header; the function rejects any call
#   without this secret → it is never publicly callable. Generate a random
#   value, e.g. `openssl rand -hex 32`.
#   ⚠️  Declare it TWICE, consistently:
#     1. On the Edge Function:  supabase secrets set CRON_SECRET=<value>
#     2. On the database (read by the cron via Vault):
#          select vault.create_secret('<value>', 'cron_secret');
#          select vault.create_secret('https://<project-ref>.supabase.co', 'project_url');
#
CRON_SECRET=REPLACE_WITH_A_RANDOM_SECRET

# Optional parameters (defaults defined in _shared/models.ts):
#   COUNCIL_TIMEOUT_MS        — per-model timeout, ms          (default 30000)
#   RATE_LIMIT_WINDOW_SECONDS — IP rate-limit window, s        (default 60)
#   RATE_LIMIT_MAX_REQUESTS   — max requests / window / IP      (default 8)
#   ALLOWED_ORIGIN            — allowed CORS origin             (default *)
#   OPENROUTER_REFERER        — OpenRouter attribution header
#
# COUNCIL_TIMEOUT_MS=30000
# RATE_LIMIT_WINDOW_SECONDS=60
# RATE_LIMIT_MAX_REQUESTS=8
# ALLOWED_ORIGIN=http://localhost:5173

# ─── Public app configuration ─────────────────────────────────────────
#
# Public URL of the app (used to generate OG links, share links, etc.)
# In development: http://localhost:5173
# In production: https://quorum.app (or your own domain)
#
VITE_APP_URL=http://localhost:5173

# ─── Vercel deployment (share SSR + OG image) ─────────────────────────
#
# The api/ serverless functions (public page /q/{slug}, OG image, sitemap)
# read Supabase via REST with the anon key. On Vercel, declare these variables
# in Project Settings → Environment Variables (they then become available
# to the function via process.env). The functions accept both names:
#   SUPABASE_URL / VITE_SUPABASE_URL            (project URL)
#   SUPABASE_ANON_KEY / VITE_SUPABASE_ANON_KEY  (PUBLIC anon key)
#   VITE_APP_URL                                (public domain, e.g. https://quorum.app)
# No service_role key here: everything goes through RLS + public RPCs.

# ─── Feature flags (optional) ─────────────────────────────────────────
#
# Enable/disable features under development.
# "true" | "false" — prefixed VITE_ because used client-side.
#
VITE_FEATURE_QUESTION_DU_JOUR=false
VITE_FEATURE_BYOK=false

# Reverse-trial: X days of PRO granted to new accounts (under testing).
#   → Disabled by default. The actual grant and its uniqueness are enforced
#     server-side (RPC start_reverse_trial, migration 0019). The duration is
#     authoritative in the database (billing_config.reverse_trial_days);
#     VITE_REVERSE_TRIAL_DAYS is only a display mirror.
VITE_FEATURE_REVERSE_TRIAL=false
VITE_REVERSE_TRIAL_DAYS=7

# ─── Freemium monetization (open-core) ────────────────────────────────
#
# Configurable FREE quotas (client mirror of the billing_config table, which
# stays authoritative server-side). Adjust without touching the code.
#   VITE_FREE_DAILY_QUESTIONS_ANON  — questions/day without account (default 5)
#   VITE_FREE_DAILY_QUESTIONS       — questions/day with account    (default 10)
#
VITE_FREE_DAILY_QUESTIONS_ANON=5
VITE_FREE_DAILY_QUESTIONS=10

# Payment provider. At MVP: "none" → NO payment triggered, the PRO CTAs
# stay informational. To enable later, prefer a MERCHANT OF RECORD
# (lemonsqueezy | polar | paddle) over "stripe" — see docs/MONETISATION.md
# (the publisher being a minor, the MoR handles VAT/compliance).
#   "none" | "lemonsqueezy" | "polar" | "paddle" | "stripe"
VITE_BILLING_PROVIDER=none

# ─── Analytics (optional) ─────────────────────────────────────────────
#
# PostHog for analytics (free tier available at https://posthog.com)
# Prefixed VITE_ because the PostHog SDK runs in the browser.
#
# VITE_POSTHOG_KEY=phc_REPLACE_WITH_YOUR_KEY
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
