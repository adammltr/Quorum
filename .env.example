# ══════════════════════════════════════════════════════════════════════
# Quorum — Variables d'environnement
# ══════════════════════════════════════════════════════════════════════
#
# INSTRUCTIONS :
#   1. Copie ce fichier : cp .env.example .env.local
#   2. Remplis chaque valeur (ne laisse JAMAIS une vraie clé dans .env.example)
#   3. .env.local est dans .gitignore — il ne sera jamais commité
#
# ⚠️  RÈGLE CLIENT vs SERVEUR :
#   - Les variables préfixées VITE_  sont exposées au navigateur.
#     → N'y mets QUE des valeurs publiques (URL, clé anon publique).
#   - Les variables SANS préfixe VITE_  restent côté serveur.
#     → Supabase Edge Functions (Deno) ou backend uniquement.
#     → JAMAIS accessibles par le code React/Vite côté client.
#
# ══════════════════════════════════════════════════════════════════════

# ─── OpenRouter ───────────────────────────────────────────────────────
#
# Obtenir une clé GRATUITE :
#   1. Va sur https://openrouter.ai/
#   2. Crée un compte (GitHub/Google acceptés)
#   3. Dashboard → Keys → "Create Key"
#   4. Les modèles suffixés ":free" sont utilisables sans crédits
#      (ex: meta-llama/llama-3.3-70b-instruct:free)
#   5. Pour les modèles premium, ajoute des crédits ($5 minimum)
#
# ⚠️  Cette clé est un SECRET SERVEUR — elle ne doit jamais
#     apparaître dans le code client ni dans les variables VITE_.
#     Elle est utilisée uniquement dans les Supabase Edge Functions.
#
OPENROUTER_API_KEY=sk-or-v1-REMPLACE_PAR_TA_VRAIE_CLE

# ─── Supabase ─────────────────────────────────────────────────────────
#
# Obtenir ces valeurs GRATUITEMENT :
#   1. Va sur https://supabase.com/
#   2. Crée un compte et un nouveau projet (tier Free)
#   3. Settings → API → trouve les 3 valeurs ci-dessous
#
# VITE_SUPABASE_URL — PUBLIC (exposé au client)
#   C'est l'URL de ton projet Supabase, visible dans Settings → API
#   Format : https://[project-ref].supabase.co
#   → Préfixé VITE_ car le client React en a besoin pour faire des requêtes.
#
VITE_SUPABASE_URL=https://REMPLACE_PAR_TON_PROJECT_REF.supabase.co

# VITE_SUPABASE_ANON_KEY — PUBLIC (exposé au client, c'est volontaire)
#   La clé "anon" (anonyme) est PUBLIQUE par design chez Supabase.
#   Elle ne permet d'accéder qu'aux données autorisées par les Row Level
#   Security (RLS) policies. C'est safe de l'exposer au client.
#   Settings → API → "anon public"
#   → Préfixé VITE_ car le SDK Supabase côté client en a besoin.
#
VITE_SUPABASE_ANON_KEY=eyJSEMPLE_REMPLACE_PAR_TA_VRAIE_ANON_KEY

# SUPABASE_SERVICE_ROLE_KEY — SECRET SERVEUR ⛔ JAMAIS côté client
#   La clé "service_role" bypasse TOUTES les RLS policies.
#   Elle donne un accès administrateur complet à ta base de données.
#   → Utilisée UNIQUEMENT dans les Supabase Edge Functions (côté serveur).
#   → JAMAIS de préfixe VITE_ — ne doit jamais atteindre le navigateur.
#   Settings → API → "service_role" (clique sur "Reveal")
#
SUPABASE_SERVICE_ROLE_KEY=eyJSEMPLE_REMPLACE_PAR_TA_VRAIE_SERVICE_ROLE_KEY

# ─── Configuration publique de l'app ──────────────────────────────────
#
# URL publique de l'app (utilisée pour générer les liens OG, partage, etc.)
# En développement : http://localhost:5173
# En production : https://quorum.app (ou ton domaine)
#
VITE_APP_URL=http://localhost:5173

# ─── Feature flags (optionnel) ────────────────────────────────────────
#
# Activer/désactiver des features en cours de développement.
# "true" | "false" — préfixé VITE_ car utilisé côté client.
#
VITE_FEATURE_QUESTION_DU_JOUR=false
VITE_FEATURE_BYOK=false

# ─── Analytiques (optionnel) ──────────────────────────────────────────
#
# PostHog pour les analytics (tier free disponible sur https://posthog.com)
# Préfixé VITE_ car le SDK PostHog tourne dans le navigateur.
#
# VITE_POSTHOG_KEY=phc_REMPLACE_PAR_TA_CLE
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
