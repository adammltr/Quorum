{
  "//": "Config Deno des Edge Functions Quorum. Import map centralisé + tasks de dev.",
  "imports": {
    "@supabase/supabase-js": "jsr:@supabase/supabase-js@2",
    "@std/assert": "jsr:@std/assert@1",
    "@std/encoding/base64": "jsr:@std/encoding@1/base64"
  },
  "tasks": {
    "test": "deno test --allow-none _tests/",
    "check": "deno check council/index.ts",
    "lint": "deno lint ."
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "lineWidth": 90,
    "singleQuote": true,
    "semiColons": false
  }
}
